# GSD framework install (per-user dev tooling, regeneratable via GSD install).
# The repo tracks only the curated FAMP-specific .claude files (famp-* commands/
# skills, settings.json); everything GSD/Codex installs locally is ignored.
.claude/.gsd-profile
.claude/agents/
.claude/commands/gsd-*.md
.claude/gsd-core/
.claude/gsd-file-manifest.json
.claude/gsd-install-state.json
.claude/gsd-migration-journal/
.claude/hooks/
.claude/package.json
.claude/scripts/
.codex/

