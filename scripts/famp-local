#!/usr/bin/env bash
# famp-local — same-host onboarding wrapper for FAMP v0.8.
#
# Wraps `famp setup / listen / info / peer import / send / inbox` into a
# small command surface optimised for two MCP-capable agent windows on the same
# laptop. This is explicit pre-v0.9 scaffolding: it does NOT replace v0.8,
# it just hides the parts that don't matter for the same-UID use case
# (port selection, HOME juggling, peer-card piping, TOFU first-contact).
#
# Intentional non-goals:
#   * Channels / broadcast (use v0.9 for that)
#   * Hot-reloading MCP client config (clients read at start)
#   * Cross-host federation (v1.0)
#
# Usage: see `famp-local help`

set -euo pipefail

STATE_ROOT="${FAMP_LOCAL_ROOT:-$HOME/.famp-local}"
FAMP_BIN="${FAMP_BIN:-famp}"
BASE_PORT="${FAMP_LOCAL_BASE_PORT:-8443}"

# Absolute path to this script, for baking into ~/.zprofile — has to work
# when the hook fires from a new login shell whose cwd isn't the repo.
if [ -L "${BASH_SOURCE[0]}" ]; then
  FAMP_LOCAL_SCRIPT="$(readlink "${BASH_SOURCE[0]}")"
else
  FAMP_LOCAL_SCRIPT="${BASH_SOURCE[0]}"
fi
case "$FAMP_LOCAL_SCRIPT" in
  /*) ;;
  *)  FAMP_LOCAL_SCRIPT="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/$(basename "${BASH_SOURCE[0]}")" ;;
esac

# ─── paths ─────────────────────────────────────────────────────────────

home_for() { echo "$STATE_ROOT/agents/$1"; }
pid_for()  { echo "$STATE_ROOT/agents/$1/daemon.pid"; }
log_for()  { echo "$STATE_ROOT/agents/$1/daemon.log"; }

# ─── helpers ───────────────────────────────────────────────────────────

die() { printf 'famp-local: %s\n' "$*" >&2; exit 1; }
note() { printf '  %s\n' "$*" >&2; }

require_famp() {
  command -v "$FAMP_BIN" >/dev/null 2>&1 \
    || die "famp binary not found on PATH (set FAMP_BIN=... to override)"
}

# Return 0 if PID in $1 is alive, 1 otherwise.
is_alive() {
  local pid="$1"
  [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null
}

# Normalise a user-supplied directory path: expand ~, make absolute, drop
# trailing slash. Does NOT require the directory to exist — caller checks.
resolve_dir() {
  local dir="$1"
  dir="${dir/#\~/$HOME}"
  case "$dir" in
    /*) ;;
    *) dir="$PWD/$dir" ;;
  esac
  dir="${dir%/}"
  printf '%s\n' "$dir"
}

# Enforce alphanumeric + underscore + hyphen on identity names. Matches
# what v0.8 `famp setup --name` accepts without surprises.
validate_identity_name() {
  local n="$1"
  case "$n" in
    ''|*[!A-Za-z0-9_-]*) die "invalid identity name '$n' (allowed: A-Z a-z 0-9 _ -)" ;;
  esac
}

# Space-separated list of identity names currently present under STATE_ROOT.
# Empty string if none exist yet.
list_existing_agents_inline() {
  [ -d "$STATE_ROOT/agents" ] || { printf ''; return 0; }
  ( cd "$STATE_ROOT/agents" && ls -1 2>/dev/null ) | tr '\n' ' '
}

# Rewrite the login-hook line in ~/.zprofile so it reflects the given
# space-separated mesh list. If no managed block exists, strip any
# pre-existing unmanaged `famp-local init` line first (from early hand-rolled
# setups), then append the managed block. Managed block is delimited by the
# marker comment so future rewrites can find-and-replace cleanly.
ZPROFILE_MARKER="# FAMP local login hook (managed by famp-local)"
update_zprofile_init() {
  local mesh="$1"
  local zp="$HOME/.zprofile"
  local new_line="$FAMP_LOCAL_SCRIPT init $mesh >/dev/null 2>&1 || true"
  touch "$zp"

  local tmp; tmp="$(mktemp)"

  if grep -Fq "$ZPROFILE_MARKER" "$zp"; then
    # Managed block already exists — replace the line immediately after
    # the marker.
    awk -v marker="$ZPROFILE_MARKER" -v new_line="$new_line" '
      { print }
      $0 == marker { getline; print new_line }
    ' "$zp" > "$tmp" && mv "$tmp" "$zp"
  else
    # No managed block yet. Strip any unmanaged `famp-local init` line that
    # might be left over from the early hand-rolled setup, then append a
    # fresh managed block.
    grep -v 'famp-local init' "$zp" > "$tmp" || true
    mv "$tmp" "$zp"
    {
      printf '\n%s\n' "$ZPROFILE_MARKER"
      printf '%s\n' "$new_line"
    } >> "$zp"
  fi
}

# Ports already handed out during this invocation, so a second call doesn't
# collide with the first before the listener has actually bound. Written in
# the parent shell — do NOT call next_free_port from a command substitution
# `$(...)`, which runs in a subshell and can't mutate this array. Use the
# CHOSEN_PORT out-variable instead.
PORTS_RESERVED=()
CHOSEN_PORT=""

# Pick the lowest TCP port not currently in LISTEN state AND not already
# handed out during this script run, starting from $BASE_PORT. Appends the
# chosen port to PORTS_RESERVED and sets CHOSEN_PORT.
next_free_port() {
  local p=$BASE_PORT
  local max=$((BASE_PORT + 100))
  while [ "$p" -lt "$max" ]; do
    local reserved=0
    if [ "${#PORTS_RESERVED[@]}" -gt 0 ]; then
      local t
      for t in "${PORTS_RESERVED[@]}"; do
        [ "$t" = "$p" ] && { reserved=1; break; }
      done
    fi
    if [ "$reserved" = 0 ] && \
       ! lsof -iTCP:"$p" -sTCP:LISTEN -n -P >/dev/null 2>&1; then
      PORTS_RESERVED+=("$p")
      CHOSEN_PORT="$p"
      return 0
    fi
    p=$((p+1))
  done
  die "no free TCP port found in $BASE_PORT..$((max-1))"
}

# Treat an already-assigned port (from a previously-initialised agent) as
# reserved so a fresh agent initialised in the same run doesn't steal it.
reserve_port() {
  local p="$1"
  [ -n "$p" ] || return 0
  PORTS_RESERVED+=("$p")
}

# Read the running port from an agent's config.toml (after `famp setup`).
port_of() {
  local home="$1"
  awk -F'"' '/^listen_addr[[:space:]]*=/ { print $2 }' "$home/config.toml" \
    | awk -F: '{print $NF}'
}

# List agent names currently registered under STATE_ROOT.
list_agents() {
  [ -d "$STATE_ROOT/agents" ] || return 0
  ( cd "$STATE_ROOT/agents" && ls -1 2>/dev/null )
}

# ─── lifecycle ─────────────────────────────────────────────────────────

ensure_agent() {
  local name="$1"
  local home; home="$(home_for "$name")"
  if [ -f "$home/config.toml" ]; then
    local existing_port; existing_port="$(port_of "$home")"
    reserve_port "$existing_port"
    note "$name: already initialised at $home (port $existing_port)"
    return 0
  fi
  next_free_port
  local port="$CHOSEN_PORT"
  note "$name: initialising at $home (port $port)"
  mkdir -p "$home"
  "$FAMP_BIN" setup --name "$name" --home "$home" --port "$port" \
    >/dev/null 2>&1
}

start_daemon() {
  local name="$1"
  local home; home="$(home_for "$name")"
  local pidf; pidf="$(pid_for "$name")"
  local logf; logf="$(log_for "$name")"

  if [ -f "$pidf" ]; then
    local existing; existing="$(cat "$pidf")"
    if is_alive "$existing"; then
      note "$name: daemon already running (pid $existing)"
      return 0
    else
      note "$name: stale pid file (pid $existing dead), cleaning"
      rm -f "$pidf"
    fi
  fi

  FAMP_HOME="$home" nohup "$FAMP_BIN" listen >"$logf" 2>&1 &
  local pid=$!
  echo "$pid" > "$pidf"

  # Give the listener a moment to bind before we try to connect.
  local tries=0
  local port; port="$(port_of "$home")"
  while [ "$tries" -lt 20 ]; do
    if lsof -iTCP:"$port" -sTCP:LISTEN -n -P >/dev/null 2>&1; then
      note "$name: listening on 127.0.0.1:$port (pid $pid)"
      return 0
    fi
    sleep 0.05
    tries=$((tries+1))
  done
  die "$name: daemon failed to bind port $port within 1s; see $logf"
}

stop_daemon() {
  local name="$1"
  local pidf; pidf="$(pid_for "$name")"
  [ -f "$pidf" ] || { note "$name: no pid file"; return 0; }

  local pid; pid="$(cat "$pidf")"
  if is_alive "$pid"; then
    note "$name: stopping (pid $pid)"
    kill -TERM "$pid" 2>/dev/null || true
    local tries=0
    while is_alive "$pid" && [ "$tries" -lt 40 ]; do
      sleep 0.05; tries=$((tries+1))
    done
    if is_alive "$pid"; then
      note "$name: SIGTERM ignored, escalating to SIGKILL"
      kill -KILL "$pid" 2>/dev/null || true
    fi
  fi
  rm -f "$pidf"
}

# ─── peer wiring ───────────────────────────────────────────────────────

# Import $from's peer card into $to's keyring. v0.8's `famp peer import`
# errors with `peer already exists` on a repeat rather than upserting, and
# prints even its success message ("Peer imported successfully") to stderr.
# Key on the exit code, not on stderr content: exit 0 = OK (informational
# stderr is fine), non-zero = inspect stderr for the known-idempotent case.
pair_one_way() {
  local from="$1" to="$2"
  local from_home; from_home="$(home_for "$from")"
  local to_home;   to_home="$(home_for "$to")"
  local rc=0 err
  err="$(FAMP_HOME="$from_home" "$FAMP_BIN" info \
         | FAMP_HOME="$to_home" "$FAMP_BIN" peer import 2>&1 >/dev/null)" \
    || rc=$?
  if [ "$rc" -ne 0 ]; then
    if printf '%s\n' "$err" | grep -q "peer already exists"; then
      return 0   # expected on re-run; nothing to do
    fi
    printf '%s\n' "$err" >&2
    return "$rc"
  fi
}

# For N agents, exchange peer cards in every direction (N*(N-1) imports).
exchange_peers() {
  local agents=("$@")
  local a b
  for a in "${agents[@]}"; do
    for b in "${agents[@]}"; do
      [ "$a" = "$b" ] && continue
      pair_one_way "$a" "$b"
    done
  done
  note "peer cards exchanged across: ${agents[*]}"
}

# Compute the SHA-256 fingerprint (hex, lowercase) of the leaf cert at
# $1 (PEM). This is the format `famp` pins in peers.toml.
cert_fingerprint_sha256() {
  openssl x509 -in "$1" -outform DER 2>/dev/null \
    | shasum -a 256 \
    | awk '{ print $1 }'
}

# Append `tls_fingerprint_sha256 = "<fp>"` into the peers.toml block for
# alias $alias in file $peers_file. Replaces any existing pin for that
# alias, so the operation is idempotent. Written in awk so we don't take
# a toml-crate dependency.
pin_peer_fingerprint() {
  local peers_file="$1" alias="$2" fp="$3"
  local tmp="${peers_file}.tmp"
  awk -v target="$alias" -v fp="$fp" '
    BEGIN { in_block = 0; matched = 0; printed_fp = 0; }
    /^\[\[peers\]\]$/ {
      if (in_block && matched && !printed_fp) {
        print "tls_fingerprint_sha256 = \"" fp "\""
      }
      in_block = 1; matched = 0; printed_fp = 0;
      print; next;
    }
    in_block && $0 ~ "^alias = \"" target "\"$" {
      matched = 1; print; next;
    }
    in_block && matched && /^tls_fingerprint_sha256[[:space:]]*=/ {
      # Replace existing pin in place.
      print "tls_fingerprint_sha256 = \"" fp "\"";
      printed_fp = 1; next;
    }
    { print }
    END {
      if (in_block && matched && !printed_fp) {
        print "tls_fingerprint_sha256 = \"" fp "\""
      }
    }
  ' "$peers_file" > "$tmp" && mv "$tmp" "$peers_file"
}

# Pre-pin every agent's fingerprint into every other agent's peers.toml
# by reading the cert files directly. Skips TOFU entirely — honest, because
# we trust the filesystem on same-UID loopback anyway.
pin_all_fingerprints() {
  local agents=("$@")
  local from to fp
  for from in "${agents[@]}"; do
    for to in "${agents[@]}"; do
      [ "$from" = "$to" ] && continue
      fp="$(cert_fingerprint_sha256 "$(home_for "$to")/tls.cert.pem")"
      pin_peer_fingerprint "$(home_for "$from")/peers.toml" "$to" "$fp"
    done
  done
  note "TLS fingerprints pre-pinned from cert files (TOFU bypassed)"
}

# ─── subcommands ───────────────────────────────────────────────────────

cmd_init() {
  [ $# -ge 2 ] || die "init needs at least two names, e.g. 'famp-local init alice bob'"
  local agents=("$@")

  mkdir -p "$STATE_ROOT/agents"
  local a
  # Order matters: the listen daemon loads its keyring once at startup,
  # so peers.toml MUST be fully populated (pubkeys + pins) before we
  # `famp listen`. Otherwise bob's daemon has no record of alice and
  # rejects her signed envelopes as HTTP 401 Unauthorized.
  for a in "${agents[@]}"; do ensure_agent "$a"; done
  exchange_peers       "${agents[@]}"
  pin_all_fingerprints "${agents[@]}"
  for a in "${agents[@]}"; do start_daemon  "$a"; done

  echo
  echo "✓ ${#agents[@]} agents ready: ${agents[*]}"
  echo "  state:  $STATE_ROOT"
  echo
  echo "  Send from shell:"
  echo "    $FAMP_LOCAL_SCRIPT send ${agents[0]} ${agents[1]} 'hello'"
  echo
  echo "  Register as MCP servers:"
  echo "    $FAMP_LOCAL_SCRIPT mcp-add ${agents[*]}                 # Claude Code"
  echo "    $FAMP_LOCAL_SCRIPT mcp-add --client codex ${agents[*]} # Codex (global in ~/.codex/config.toml)"
}

cmd_send() {
  [ $# -eq 3 ] || die "send <from> <to> <text>"
  local from="$1" to="$2" text="$3"
  local home; home="$(home_for "$from")"
  [ -d "$home" ] || die "unknown agent: $from (run 'famp-local init $from' first)"
  FAMP_HOME="$home" "$FAMP_BIN" send --to "$to" --new-task "$text"
}

cmd_inbox() {
  [ $# -eq 1 ] || die "inbox <name>"
  local name="$1"
  local home; home="$(home_for "$name")"
  [ -d "$home" ] || die "unknown agent: $name"
  FAMP_HOME="$home" "$FAMP_BIN" inbox list
}

cmd_status() {
  local found=0
  local a
  for a in $(list_agents); do
    found=1
    local pidf; pidf="$(pid_for "$a")"
    local home; home="$(home_for "$a")"
    local port; port="$(port_of "$home")"
    if [ -f "$pidf" ]; then
      local pid; pid="$(cat "$pidf")"
      if is_alive "$pid"; then
        printf '  %-16s running  pid=%s  port=%s  home=%s\n' "$a" "$pid" "$port" "$home"
      else
        printf '  %-16s stopped  (stale pid %s)  port=%s\n' "$a" "$pid" "$port"
      fi
    else
      printf '  %-16s stopped                  port=%s\n' "$a" "$port"
    fi
  done
  [ "$found" = 1 ] || echo "  (no agents — run 'famp-local init <name> <name>')"
}

cmd_stop() {
  if [ $# -eq 0 ]; then
    local a
    for a in $(list_agents); do stop_daemon "$a"; done
  else
    for a in "$@"; do stop_daemon "$a"; done
  fi
}

cmd_clean() {
  cmd_stop
  if [ -d "$STATE_ROOT" ]; then
    note "removing $STATE_ROOT"
    rm -rf "$STATE_ROOT"
  fi
  echo "✓ state cleaned"
}

# Register one or more agents as user-scope MCP servers for Claude Code,
# Codex, or both. Uses the absolute path to the famp binary so the client
# MCP spawner doesn't need the user's PATH.
cmd_mcp_add() {
  local client="claude"
  while [ $# -gt 0 ]; do
    case "$1" in
      --client)
        shift; [ $# -ge 1 ] || die "--client needs one of: claude, codex, both"
        client="$1"; shift ;;
      --client=*)
        client="${1#--client=}"; shift ;;
      --*)
        die "unknown flag: $1 (try 'famp-local help')" ;;
      *)
        break ;;
    esac
  done

  [ $# -ge 1 ] || die "mcp-add [--client claude|codex|both] <name> [<name>...]"

  case "$client" in
    claude|codex|both) ;;
    *) die "invalid client '$client' (expected: claude, codex, both)" ;;
  esac

  local famp_abs; famp_abs="$(command -v "$FAMP_BIN")"
  local a home

  for a in "$@"; do
    home="$(home_for "$a")"
    [ -d "$home" ] || die "unknown agent: $a (init it first)"
  done

  if [ "$client" = "claude" ] || [ "$client" = "both" ]; then
    command -v claude >/dev/null 2>&1 \
      || die "'claude' CLI not on PATH; install Claude Code or use --client codex"
    for a in "$@"; do
      home="$(home_for "$a")"
      claude mcp remove --scope user "famp-$a" >/dev/null 2>&1 || true
      claude mcp add    --scope user "famp-$a" "$famp_abs" mcp >/dev/null
      note "Claude: famp-$a registered → $famp_abs mcp  (run 'register as $a' in window)"
    done
  fi

  if [ "$client" = "codex" ] || [ "$client" = "both" ]; then
    command -v codex >/dev/null 2>&1 \
      || die "'codex' CLI not on PATH; install Codex or use --client claude"
    for a in "$@"; do
      home="$(home_for "$a")"
      codex mcp remove "famp-$a" >/dev/null 2>&1 || true
      codex mcp add "famp-$a" -- "$famp_abs" mcp >/dev/null
      note "Codex:  famp-$a registered → $famp_abs mcp  (run 'register as $a' in window)"
    done
  fi

  echo
  case "$client" in
    claude) echo "✓ MCP servers registered. Restart Claude Code windows for them to pick up." ;;
    codex)  echo "✓ MCP servers registered. Restart Codex windows for them to pick up." ;;
    both)   echo "✓ MCP servers registered. Restart Claude Code and Codex windows for them to pick up." ;;
  esac
}

# Remove one or more user-scope MCP registrations for Claude Code, Codex,
# or both. Does not delete FAMP state; only unregisters the MCP servers.
cmd_mcp_remove() {
  local client="both"
  while [ $# -gt 0 ]; do
    case "$1" in
      --client)
        shift; [ $# -ge 1 ] || die "--client needs one of: claude, codex, both"
        client="$1"; shift ;;
      --client=*)
        client="${1#--client=}"; shift ;;
      --*)
        die "unknown flag: $1 (try 'famp-local help')" ;;
      *)
        break ;;
    esac
  done

  [ $# -ge 1 ] || die "mcp-remove [--client claude|codex|both] <name> [<name>...]"

  case "$client" in
    claude|codex|both) ;;
    *) die "invalid client '$client' (expected: claude, codex, both)" ;;
  esac

  local a
  if [ "$client" = "claude" ] || [ "$client" = "both" ]; then
    command -v claude >/dev/null 2>&1 \
      || die "'claude' CLI not on PATH; install Claude Code or use --client codex"
    for a in "$@"; do
      claude mcp remove --scope user "famp-$a" >/dev/null 2>&1 || true
      note "Claude: removed MCP server famp-$a"
    done
  fi

  if [ "$client" = "codex" ] || [ "$client" = "both" ]; then
    command -v codex >/dev/null 2>&1 \
      || die "'codex' CLI not on PATH; install Codex or use --client claude"
    for a in "$@"; do
      codex mcp remove "famp-$a" >/dev/null 2>&1 || true
      note "Codex:  removed MCP server famp-$a"
    done
  fi

  echo
  case "$client" in
    claude) echo "✓ Claude Code MCP servers removed. Restart Claude Code windows if they are open." ;;
    codex)  echo "✓ Codex MCP servers removed. Restart Codex windows if they are open." ;;
    both)   echo "✓ MCP servers removed from Claude Code and Codex. Restart any open windows." ;;
  esac
}

cmd_wire() {
  [ $# -ge 1 ] || die "wire <dir> [--as <name>] [--force]"
  local dir="$1"; shift
  local override_name="" force=0
  while [ $# -gt 0 ]; do
    case "$1" in
      --as)    shift; [ $# -ge 1 ] || die "--as needs an identity name"
               override_name="$1"; shift ;;
      --force) force=1; shift ;;
      *)       die "unknown flag: $1 (try 'famp-local help')" ;;
    esac
  done

  dir="$(resolve_dir "$dir")"
  [ -d "$dir" ] || die "directory does not exist: $dir"

  local name
  if [ -n "$override_name" ]; then
    name="$override_name"
  else
    name="$(basename "$dir")"
  fi
  validate_identity_name "$name"

  local mcp_file="$dir/.mcp.json"

  # Build the full mesh: every existing agent + the target identity.
  # Deduplicated so re-wiring a repo that's already in the mesh doesn't
  # double-list it.
  local existing; existing="$(list_existing_agents_inline)"
  local mesh="$existing"
  local found=0
  for e in $existing; do
    [ "$e" = "$name" ] && { found=1; break; }
  done
  if [ "$found" = 0 ]; then
    mesh="$existing $name"
  fi
  # trim surrounding whitespace
  # shellcheck disable=SC2086
  mesh="$(echo $mesh)"

  # init handles "create missing, start missing, idempotent for existing"
  # and requires at least two agents. If the user is wiring their very
  # first repo, auto-invent a second placeholder so init doesn't reject.
  local mesh_count=0
  for _ in $mesh; do mesh_count=$((mesh_count + 1)); done
  if [ "$mesh_count" -lt 2 ]; then
    # First-call bootstrap: invent a neutral placeholder so cmd_init's
    # ≥2-agent precondition is satisfied. 'bootstrap' was chosen for being
    # short, neutral, and evocative of "first peer to get the mesh going" —
    # it's deliberately unlikely to collide with real workload identities
    # like 'main', 'default', 'local', or repo basenames. If the user
    # actually picked 'bootstrap' as their --as name, fall back to
    # 'bootstrap2' so the two mesh entries stay distinct.
    local placeholder
    if [ "$name" = "bootstrap" ]; then
      placeholder="bootstrap2"
    else
      placeholder="bootstrap"
    fi
    validate_identity_name "$placeholder"
    mesh="$mesh $placeholder"
    # shellcheck disable=SC2086,SC2116
    mesh="$(echo $mesh)"
    note "first-time bootstrap: auto-inventing placeholder identity '$placeholder' so the mesh has two members; safe to leave or unwire later"
  fi

  note "wiring: identity='$name', target=$dir"
  note "mesh will be: $mesh"

  # Running daemons cached their keyring at startup. If we added a new peer
  # to their peers.toml without bouncing them, they'd reject signed
  # envelopes from the new identity with HTTP 401. Stop first, then init
  # rebuilds the keyring fresh on every daemon. Brief outage (<2s) for any
  # existing sessions; acceptable for a dev workflow.
  cmd_stop >/dev/null 2>&1 || true
  # shellcheck disable=SC2086
  cmd_init $mesh

  require_famp
  local famp_abs; famp_abs="$(command -v "$FAMP_BIN")"
  local home; home="$(home_for "$name")"
  # Note: $home is computed but no longer written into the .mcp.json — it is only
  # used downstream for update_zprofile_init and the README hint.
  # Per .planning/phases/01-session-bound-mcp-identity/01-CONTEXT.md variant
  # B-strict: every new MCP-launched window must call famp_register itself.

  # Build the desired-state contents into a variable so the same string is used
  # for both the byte-exact comparison AND the write — guarantees compare and
  # writer agree (mitigates T-04-01).
  local desired_template
  desired_template="$(printf '{
  "mcpServers": {
    "famp": {
      "command": "%s",
      "args": ["mcp"]
    }
  }
}' "$famp_abs")"

  if [ -f "$mcp_file" ]; then
    # Idempotent: if the on-disk file already matches the desired template,
    # no-op (skip the write). Otherwise rewrite in place — this is the
    # auto-migration path for repos previously wired with FAMP_HOME in env.
    # --force is honored for cosmetic re-rendering of an already-migrated file.
    if [ "$force" = 1 ] || ! printf '%s\n' "$desired_template" | cmp -s - "$mcp_file"; then
      printf '%s\n' "$desired_template" > "$mcp_file"
      note "rewrote $mcp_file → identity '$name' (auto-migration: dropped FAMP_HOME)"
    else
      note "$mcp_file already on the new template (no change)"
    fi
  else
    printf '%s\n' "$desired_template" > "$mcp_file"
    note "wrote $mcp_file → identity '$name'"
  fi

  update_zprofile_init "$mesh"
  note "updated ~/.zprofile login hook (mesh: $mesh)"

  echo
  echo "✓ $dir wired (mesh: $mesh)"
  echo "  In every new Claude Code window opened in $dir, run:"
  echo "    register as $name"
  echo "  In Codex, after '$FAMP_LOCAL_SCRIPT mcp-add --client codex $name', run:"
  echo "    register as $name"
  echo "  Use 'famp_whoami' to confirm the binding inside any window."
}

cmd_unwire() {
  [ $# -eq 1 ] || die "unwire <dir>"
  local dir; dir="$(resolve_dir "$1")"
  local mcp_file="$dir/.mcp.json"
  [ -f "$mcp_file" ] || die "no .mcp.json at $mcp_file (nothing to unwire)"

  # Pre-migration .mcp.json files contained FAMP_HOME, post-migration files do
  # not. Either way, the dir name is enough for the hint.
  local name; name="$(basename "$dir")"

  rm -f "$mcp_file"
  note "removed $mcp_file"
  echo
  echo "✓ $dir unwired"
  if [ -n "$name" ]; then
    echo
    echo "  Identity '$name' is still in the mesh and will keep starting at login."
    echo "  If you registered it with Codex, unregister it separately:"
    echo "    $FAMP_LOCAL_SCRIPT mcp-remove --client codex $name"
    echo
    echo "  To fully remove the identity (stop its daemon, delete its state):"
    echo "    $FAMP_LOCAL_SCRIPT stop"
    echo "    rm -rf $STATE_ROOT/agents/$name"
    echo "    $FAMP_LOCAL_SCRIPT init <remaining names>"
    echo "  Then edit ~/.zprofile to drop '$name' from the login hook."
  fi
}

cmd_help() {
  cat <<'EOF'
famp-local — same-host onboarding wrapper for FAMP v0.8.

COMMANDS
  init <name> [<name>...]         Create N agents, start daemons, exchange pins.
  wire <dir> [--as <name>] [--force]
                                  Bring a directory into the mesh: ensure an
                                  identity named <name> (default: basename of
                                  <dir>) exists, drop a project-scoped
                                  .mcp.json in <dir>, update ~/.zprofile.
  unwire <dir>                    Remove .mcp.json from <dir>. Identity and
                                  daemon stay — hint printed for full removal.
  send <from> <to> <text>         Send a new_task from one agent to another.
  inbox <name>                    List a name's inbox entries.
  status                          Show all known agents and daemon state.
  stop [<name>...]                Stop daemon(s); with no args, stops all.
  clean                           Stop everything and wipe state dir.
  mcp-add [--client <target>] <name> [<name>...]
                                  Register agent(s) as user-scope MCP servers.
                                  target = claude | codex | both
  mcp-remove [--client <target>] <name> [<name>...]
                                  Remove user-scope MCP server registrations.
                                  target = claude | codex | both
  help                            Show this message.

ENVIRONMENT
  FAMP_BIN             Path to famp binary (default: 'famp' on PATH).
  FAMP_LOCAL_ROOT      State dir (default: ~/.famp-local).
  FAMP_LOCAL_BASE_PORT First port to try when auto-assigning (default: 8443).

MCP USAGE
  After 'wire <dir>', restart the Claude Code or Codex window for that repo.
  In every new window, register the identity before sending messages:
    "register as <name>"   (or call famp_register with identity=<name>)
  Without this step, famp_send / famp_inbox / famp_await / famp_peers
  return a typed 'not_registered' error.

EXAMPLE
  $ famp-local init alice bob
  $ famp-local wire ~/Workspace/MyRepo
  $ famp-local wire ~/Workspace/God --as architect
  $ famp-local send alice bob 'ship it'
  $ famp-local inbox bob
  $ famp-local unwire ~/Workspace/MyRepo
EOF
}

# ─── dispatch ──────────────────────────────────────────────────────────

cmd="${1:-help}"; shift || true
case "$cmd" in
  init)    require_famp; cmd_init "$@" ;;
  wire)    require_famp; cmd_wire "$@" ;;
  unwire)                 cmd_unwire "$@" ;;
  send)    require_famp; cmd_send "$@" ;;
  inbox)   require_famp; cmd_inbox "$@" ;;
  status)                 cmd_status "$@" ;;
  stop)                   cmd_stop "$@" ;;
  clean)                  cmd_clean "$@" ;;
  mcp-add) require_famp; cmd_mcp_add "$@" ;;
  mcp-remove)            cmd_mcp_remove "$@" ;;
  help|-h|--help)         cmd_help ;;
  *)       die "unknown command: $cmd (try 'famp-local help')" ;;
esac
