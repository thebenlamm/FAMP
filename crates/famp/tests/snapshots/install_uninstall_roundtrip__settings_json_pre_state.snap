---
source: crates/famp/tests/install_uninstall_roundtrip.rs
expression: post_settings
---
{
  "env": {
    "MY_VAR": "abc"
  },
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "command": "/some/pre-hook.sh",
            "type": "command"
          }
        ],
        "matcher": "Edit|Write"
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "command": "/some/other-stop.sh",
            "timeout": 60,
            "type": "command"
          }
        ],
        "matcher": ""
      }
    ]
  },
  "model": "opus",
  "permissions": {
    "allow": [
      "Bash(git:*)",
      "WebFetch(*)"
    ],
    "deny": []
  }
}
